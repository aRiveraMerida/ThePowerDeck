{
  "name": "thepower-deck-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Generador de presentaciones HTML 16:9 con el sistema visual de thePower. 100% navegador, sin backend.",
  "scripts": {
    "build": "node build.mjs && node tests/smoke.mjs",
    "build:only": "node build.mjs",
    "test": "node tests/smoke.mjs",
    "pretest:e2e": "node build.mjs",
    "test:e2e": "playwright test",
    "test:visual:update": "node build.mjs && playwright test tests/visual.spec.mjs --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
